# Rail Drishti — Environment Configuration
# Copy this file to .env and fill in your values

# ── Backend ─────────────────────────────────────────────────────────────────
RAILWAYS_DATA_DIR=./data          # Path to the data directory
BACKEND_PORT=8000                  # Port to run the FastAPI server

# ── RAG / AI Features (optional) ─────────────────────────────────────────────
# Required only for the RAG TDR Advisory feature (notebooks/rag_tdr.ipynb)
GROQ_API_KEY=your_groq_api_key_here

# ── Databricks (optional) ─────────────────────────────────────────────────────
# Required only if running the Databricks-native notebooks on a cluster
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=your_databricks_token_here
